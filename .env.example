# =========================================
# Samarth Kisan AI - Environment Variables
# =========================================

# ---- Backend (Cloudflare Worker secrets) ----
# Set with: wrangler secret put GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# ---- Google Cloud (Firestore + Cloud Storage) ----
# Firestore is the database, Cloud Storage holds crop disease photos, and a
# Firestore "cache" collection replaces Cloudflare KV. All are reached over
# REST using a service account (no Node-only Google SDKs, so this stays
# Workers-compatible). See README "Google Cloud Setup" for how to create
# these.
GCP_PROJECT_ID=your-gcp-project-id
# Set with: wrangler secret put GCP_SERVICE_ACCOUNT_EMAIL
GCP_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Set with: wrangler secret put GCP_SERVICE_ACCOUNT_PRIVATE_KEY
# (the "private_key" field from the downloaded service account JSON key)
GCP_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GCS_BUCKET_NAME=samarth-kisan-ai-images

# ---- Auth (Firebase Authentication — Phone/SMS OTP) ----
# No backend secret needed: ID tokens are verified with Google's public keys
# (see backend/src/services/firebaseAuthService.ts). Enable "Phone" as a
# sign-in provider in the Firebase Console for the project matching
# GCP_PROJECT_ID above, then set the frontend's PUBLIC_FIREBASE_* vars below.

# Optional: real data providers (fallback simulators are used if unset)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
INDIA_WRIS_API_KEY=
SOILGRIDS_BASE_URL=https://rest.isric.org/soilgrids/v2.0
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_GEOCODE_URL=https://geocoding-api.open-meteo.com/v1

# Optional: SMS provider (MSG91 / Twilio). Advisory text is always generated;
# actual sending is a no-op stub until these are configured.
SMS_PROVIDER=msg91
SMS_API_KEY=
SMS_SENDER_ID=KISANA

# ---- Frontend (public, safe to expose) ----
PUBLIC_API_BASE_URL=http://localhost:8787
PUBLIC_APP_NAME=Samarth Kisan AI
PUBLIC_DEFAULT_LANGUAGE=hi

# Firebase web app config (Firebase Console > Project settings > Your apps > Web app)
PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
