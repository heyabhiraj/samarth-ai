# Local-only secrets for `wrangler dev`. Copy to `.dev.vars` (gitignored) and
# fill in real values — wrangler.toml `[vars]` are non-secret and already set;
# these are the ones you'd otherwise set with `wrangler secret put` in prod.

GEMINI_API_KEY=your_gemini_api_key_here
GCP_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# No auth secret is needed here — Firebase ID tokens are verified with
# Google's public keys (see backend/src/services/firebaseAuthService.ts).

# Optional
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
INDIA_WRIS_API_KEY=
SMS_API_KEY=
