---
import Icon from "@/components/Icon.astro";
import type { AdvisoryAlert } from "@/types";

interface Props {
  alert: AdvisoryAlert;
}

const { alert } = Astro.props;

const severityStyles: Record<AdvisoryAlert["severity"], { classes: string; icon: Parameters<typeof Icon>[0]["name"] }> = {
  critical: { classes: "border-rose-400/50 bg-rose-50/80 dark:bg-rose-950/30", icon: "alert-triangle" },
  warning: { classes: "border-amber-400/50 bg-amber-50/80 dark:bg-amber-950/30", icon: "alert-triangle" },
  info: { classes: "border-sky-400/50 bg-sky-50/80 dark:bg-sky-950/30", icon: "message" },
};

const style = severityStyles[alert.severity];
---

<div class:list={["glass-panel flex items-start gap-3 border p-4 animate-slide-up", style.classes]}>
  <span class="mt-0.5 shrink-0 text-current">
    <Icon name={style.icon} class="h-5 w-5" />
  </span>
  <div>
    <p class="font-semibold text-slate-900 dark:text-white">{alert.title}</p>
    <p class="mt-0.5 text-sm text-slate-600 dark:text-slate-300">{alert.message}</p>
  </div>
</div>
