---
import Icon from "@/components/Icon.astro";

interface Props {
  confidencePct: number;
  class?: string;
}

const { confidencePct, class: className = "" } = Astro.props;

const tone =
  confidencePct >= 75
    ? "bg-kisan-100 text-kisan-700 dark:bg-kisan-900/40 dark:text-kisan-300"
    : confidencePct >= 50
      ? "bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300"
      : "bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-300";
---

<span class:list={["inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold", tone, className]}>
  <Icon name="badge-check" class="h-3.5 w-3.5" />
  {confidencePct}% confidence
</span>
