---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
---

<BaseLayout title="Login">
  <div class="mx-auto max-w-md">
    <div class="mb-6 text-center">
      <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-kisan-500 to-kisan-700 text-white shadow-md">
        <Icon name="phone" class="h-6 w-6" />
      </span>
      <h1 class="mt-3 section-heading">Welcome to Samarth Kisan AI</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">We'll text you a one-time code to sign in — no password needed.</p>
    </div>

    <!-- Step 1: phone number -->
    <form id="phone-form" class="glass-card grid gap-4 p-6 sm:p-8">
      <label class="grid gap-1.5 text-sm font-medium text-slate-700 dark:text-slate-200">
        Phone Number
        <div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white/80 px-3 py-2.5 focus-within:border-kisan-500 focus-within:ring-2 focus-within:ring-kisan-500/30 dark:border-white/10 dark:bg-slate-800/80">
          <span class="text-slate-500 dark:text-slate-400">+91</span>
          <input
            id="phone-input"
            name="phoneNumber"
            type="tel"
            required
            pattern="[0-9]{10}"
            placeholder="10-digit mobile number"
            class="w-full bg-transparent text-slate-800 placeholder:text-slate-400 focus:outline-none dark:text-white"
          />
        </div>
      </label>

      <button type="submit" id="send-otp-btn" class="btn-primary mt-2">
        <Icon name="send" class="h-4 w-4" /> Send OTP
      </button>
    </form>

    <!-- Step 2: OTP code -->
    <form id="otp-form" class="glass-card mt-4 hidden grid gap-4 p-6 sm:p-8">
      <p class="text-center text-sm text-slate-500 dark:text-slate-400">
        Enter the 6-digit code sent to <span id="otp-phone-display" class="font-semibold text-slate-700 dark:text-slate-200"></span>
      </p>
      <input
        id="otp-input"
        name="otp"
        type="text"
        inputmode="numeric"
        pattern="[0-9]{6}"
        maxlength="6"
        required
        placeholder="••••••"
        class="rounded-xl border border-slate-200 bg-white/80 px-3 py-3 text-center text-2xl tracking-[0.5em] text-slate-800 placeholder:tracking-normal placeholder:text-slate-400 focus:border-kisan-500 focus:outline-none focus:ring-2 focus:ring-kisan-500/30 dark:border-white/10 dark:bg-slate-800/80 dark:text-white"
      />
      <button type="submit" id="verify-otp-btn" class="btn-primary">
        <Icon name="check-circle" class="h-4 w-4" /> Verify &amp; Continue
      </button>
      <button type="button" id="change-number-btn" class="btn-ghost text-sm">Change phone number</button>
    </form>

    <div id="recaptcha-container"></div>
  </div>

  <script>
    import { sendOtp, confirmOtp } from "@/utils/firebase";
    import { api } from "@/services/api";
    import { showToast } from "@/utils/toast";
    import type { ConfirmationResult } from "firebase/auth";

    const phoneForm = document.getElementById("phone-form") as HTMLFormElement | null;
    const otpForm = document.getElementById("otp-form") as HTMLFormElement | null;
    const phoneInput = document.getElementById("phone-input") as HTMLInputElement | null;
    const otpInput = document.getElementById("otp-input") as HTMLInputElement | null;
    const sendOtpBtn = document.getElementById("send-otp-btn") as HTMLButtonElement | null;
    const verifyOtpBtn = document.getElementById("verify-otp-btn") as HTMLButtonElement | null;
    const otpPhoneDisplay = document.getElementById("otp-phone-display");

    let confirmationResult: ConfirmationResult | null = null;

    phoneForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const phoneNumber = phoneInput?.value.trim() ?? "";
      if (!/^[0-9]{10}$/.test(phoneNumber)) {
        showToast("Please enter a valid 10-digit phone number", "error");
        return;
      }

      if (sendOtpBtn) {
        sendOtpBtn.disabled = true;
        sendOtpBtn.textContent = "Sending...";
      }

      try {
        confirmationResult = await sendOtp(phoneNumber, "recaptcha-container");
        if (otpPhoneDisplay) otpPhoneDisplay.textContent = `+91 ${phoneNumber}`;
        phoneForm.classList.add("hidden");
        otpForm?.classList.remove("hidden");
        otpInput?.focus();
      } catch (err: any) {
        const message =
          err?.code === "auth/too-many-requests"
            ? "Too many attempts. Please try again later."
            : err?.code === "auth/invalid-phone-number"
              ? "That doesn't look like a valid phone number."
              : "Could not send the code. Please try again.";
        showToast(message, "error");
      } finally {
        if (sendOtpBtn) {
          sendOtpBtn.disabled = false;
          sendOtpBtn.innerHTML = `Send OTP`;
        }
      }
    });

    otpForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!confirmationResult) return;
      const code = otpInput?.value.trim() ?? "";

      if (verifyOtpBtn) {
        verifyOtpBtn.disabled = true;
        verifyOtpBtn.textContent = "Verifying...";
      }

      try {
        await confirmOtp(confirmationResult, code);
        const { farmer, isNewFarmer } = await api.auth.session();
        showToast(isNewFarmer ? `Welcome, ${farmer.name}!` : `Welcome back, ${farmer.name}!`, "success");
        window.location.href = "/account";
      } catch (err: any) {
        const message =
          err?.code === "auth/invalid-verification-code" || err?.code === "auth/code-expired"
            ? "That code is incorrect or expired. Please try again."
            : "Could not verify the code. Please try again.";
        showToast(message, "error");
      } finally {
        if (verifyOtpBtn) {
          verifyOtpBtn.disabled = false;
          verifyOtpBtn.innerHTML = `Verify & Continue`;
        }
      }
    });

    document.getElementById("change-number-btn")?.addEventListener("click", () => {
      confirmationResult = null;
      if (otpInput) otpInput.value = "";
      otpForm?.classList.add("hidden");
      phoneForm?.classList.remove("hidden");
    });
  </script>
</BaseLayout>
