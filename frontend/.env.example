PUBLIC_API_BASE_URL=http://localhost:8787
PUBLIC_APP_NAME=Samarth Kisan AI
PUBLIC_DEFAULT_LANGUAGE=hi

# Firebase web app config (Firebase Console > Project settings > Your apps > Web app).
# These are public identifiers, not secrets — safe to ship to the browser.
# Security comes from the backend verifying ID tokens server-side, not from hiding these.
PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
